{
  "name": "open-frame-studio-ui",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:wasm": "cd ../ofs-wasm && wasm-pack build --target web --out-dir pkg && mkdir -p ../ui/public/wasm && cp pkg/ofs_wasm.js pkg/ofs_wasm_bg.wasm ../ui/public/wasm/",
    "build:web": "npm run build:wasm && vite build",
    "dev:web": "npm run build:wasm && vite"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "svelte-i18n": "^4.0.1",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "svelte": "^5.0.0",
    "vite": "^6.0.0"
  }
}

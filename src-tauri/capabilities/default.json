{
  "identifier": "default",
  "description": "Default capabilities for Open Frame Studio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "dialog:default",
    "fs:default",
    "process:default",
    "shell:allow-open"
  ]
}
